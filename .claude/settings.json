{
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(git commit)",
        "hooks": [
          {
            "type": "command",
            "command": "cd /Users/apple/worktrees/Mycel--refactor-interaction-v2/backend && ruff check --fix . && ruff format ."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd /Users/apple/worktrees/Mycel--refactor-interaction-v2/backend && python -m py_compile \"$CLAUDE_FILE_PATH\" 2>&1 | head -5 || true"
          }
        ]
      }
    ]
  }
}
