              "en/concepts",
              "en/multi-agent-chat",
              "en/sandbox",
              "en/memory"
            ]
          },
          {
            "group": "Configuration",
            "icon": "sliders",
            "pages": [
              "en/configuration"
            ]
          },
          {
            "group": "Deploy",
            "icon": "cloud",
            "pages": [
              "en/deployment"
            ]
          }
        ]
      },
      {
        "tab": "中文",
        "icon": "languages",
        "groups": [
          {
            "group": "快速开始",
            "icon": "rocket",
            "pages": [
              "zh/introduction",
              "zh/quickstart"
            ]
          },
          {
            "group": "核心概念",
            "icon": "layers",
            "pages": [
              "zh/concepts",
              "zh/multi-agent-chat",
