# API Key (required)
OPENAI_API_KEY=your-api-key-here

# Base URL (optional, for proxy)
# 注意：必须包含 /v1，例如 https://your-proxy-url/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# Model name (optional)
MODEL_NAME=claude-sonnet-4-5-20250929

# Web search & fetch API keys (optional, for web middleware)
EXA_API_KEY=your-exa-api-key
FIRECRAWL_API_KEY=your-firecrawl-api-key
JINA_AI_API_KEY=your-jina-api-key
TAVILY_API_KEY=your-tavily-api-key

# LangSmith tracing (optional)
LANGSMITH_API_KEY=your-langsmith-api-key

# Supabase (required when STORAGE_STRATEGY=supabase)
STORAGE_STRATEGY=supabase

# SUPABASE_URL: single endpoint for all Supabase HTTP/REST calls.
# Local dev:   SUPABASE_URL=https://your-supabase-domain
# Production:  SUPABASE_URL=http://<internal-host>:8000  (injected by Coolify)
SUPABASE_URL=https://your-supabase-domain

SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Postgres direct connection (for LangGraph checkpointer, Supavisor session mode)
# Tunnel required: ssh -f -N -L 15433:localhost:5432 pgl
DATABASE_URL=postgresql://postgres.<tenant-id>:<password>@localhost:15433/postgres

